---
import "../styles/global.css";
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Oeffentliches Snooker-Scoreboard fuer schnelle Runden mit bis zu 20 Spielern."
    />
    <link rel="icon" href="/crown.svg" type="image/svg+xml" />
    <title>Snooker Scoreboard</title>
  </head>
  <body>
    <div class="page-shell">
      <nav class="site-nav" aria-label="Hauptnavigation">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true"></span>
          <span>Snooker Scoreboard</span>
        </a>
        <a class="nav-link" href="/scoreboard">Scoreboard</a>
      </nav>

      <main class="hero">
        <section class="hero-content" aria-labelledby="page-title">
          <p class="eyebrow">Match night ready</p>
          <h1 id="page-title">Snooker Scoreboard</h1>
          <p class="lead">
            Eine schlanke Scoreboard-App fuer Snooker-Runden mit Freunden:
            Spieler erfassen, Punkte buchen und die Tabelle automatisch sortieren.
          </p>
          <div class="button-row">
            <a class="primary-button" href="/scoreboard">Scoreboard starten</a>
            <a class="secondary-button" href="https://maxim.tk">Zur Hauptseite</a>
          </div>
        </section>
      </main>
    </div>
  </body>
</html>
